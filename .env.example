# mcp-rag-server 用 .env（ChromaDB版）
# このファイルを ~/mcp-rag-server/.env にコピーして使う
# cp .env.example ~/mcp-rag-server/.env

# ===== ChromaDB =====
# pgvector (Dockerなし)に変更。ディレクトリを指定するだけ。
CHROMA_PATH=./data/chroma

# ===== ソースディレクトリ =====
# Obsidian vault のパス（Windowsパスをそのまま使用可）
SOURCE_DIR=C:\Users\matuu\Desktop\GameDevelopment\DevelopmentRAGEnvironment\localRAG
PROCESSED_DIR=C:\Users\matuu\Desktop\GameDevelopment\DevelopmentRAGEnvironment\localRAG\_rag_dashboard\.processed

# ===== 埋め込みモデル =====
# 変更不要（日本語対応の高精度モデル）
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DIM=1024
EMBEDDING_PREFIX_QUERY=query:
EMBEDDING_PREFIX_EMBEDDING=passage:

# ===== Cloud RAG（notion_bulk_add.py 用） =====
# Notion Integration Token: https://www.notion.so/my-integrations
NOTION_API_KEY=

# Gemini API Key: https://aistudio.google.com/
GEMINI_API_KEY=

# Notion DB IDs（各自の Notion ワークスペースで発行した database_id に置き換える）
DB_TOOL_DOCS=
DB_GAME_INFO=
DB_RESEARCH=
DB_TEAM_NOTES=
DB_AFURI=
DB_BRAINTQ=
DB_FOURTEEN=
